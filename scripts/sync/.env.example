# Copy to .env on each CLIENT machine that pushes chats to the cockpit server.
# Each sync script reads these to know where to push.

# Cockpit server (the machine running docker-compose up).
COCKPIT_HOST=192.168.1.10
COCKPIT_USER=cockpit
COCKPIT_DATA_ROOT=/srv/cockpit/data

# A short tag identifying THIS client. Becomes a subdirectory on the server.
# Use anything unique: hostname, "laptop", "desktop", "wsl-home", etc.
CLIENT_NAME=laptop
