# ─────────────────────────────────────────────────────────────────────────────
# COCKPIT — environment configuration
# Copy this file to `.env` and fill in your own values.
# ─────────────────────────────────────────────────────────────────────────────

# Server port (web UI + API)
PORT=8000

# Timezone (used for daily audit date boundaries)
TZ=UTC

# ─── DATA SOURCES ────────────────────────────────────────────────────────────
# Where ingested chat sessions live (inside the container).
# Sync scripts on your client machines push files into these paths.
GEMINI_DATA=/app/data/gemini
CLAUDE_DATA=/app/data/claude
CLAUDE_CONVERTED=/app/data/claude_converted
CODEX_DATA=/app/data/codex
CHATGPT_SITE_DATA=/app/data/chatgpt_site

# Web-app captures (optional). Any tool that drops JSON files shaped like
# {sessionId, title, url, startTime, messages:[{role, content}]} into these
# dirs gets indexed as source=gemini/claude with machine=WEB.
GEMINI_SITE_DATA=/app/data/gemini_site
CLAUDE_SITE_DATA=/app/data/claude_site

# Seconds between filesystem index scans
INDEX_INTERVAL=150

# OPTIONAL — distilled-notes vault ("second brain"). If the directory exists and
# contains journal/YYYY-MM-DD.md files with "- " bullets, deep search also
# returns matching bullets and /api/journal serves the files. No API involved.
BRAIN_DATA=/app/data/brain

# OPTIONAL — skill name whose sessions feed the long-term memory profile
# (matched against skill_log activations). Empty = memory distiller disabled.
MEMORY_SKILL=

# ─── LLM PROVIDERS ───────────────────────────────────────────────────────────
# At least ONE provider key is required for daily/weekly digests.
# Embeddings (semantic search) need GEMINI_API_KEY.
#
# DeepSeek — used as primary for digests (cheap, JSON-mode reliable).
#   Get one at https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Google Gemini — used as fallback for digests AND for chat embeddings.
#   Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI-compatible LLM — OPTIONAL. Enables two features:
#   1. LLM reranking of search results (candidates reordered by conceptual relevance)
#   2. "Ask the Panopticon" (/api/ask): natural-language questions answered from
#      your journal (needs BRAIN_DATA), with cited dates
# Without it, search works fine (RRF-fused order) and the ask button is hidden.
#
# Cloud: set OPENAI_API_KEY (https://platform.openai.com/api-keys).
# Local, no API key at all: point OPENAI_BASE_URL at any OpenAI-compatible
# server — e.g. Ollama (http://host:11434/v1), LM Studio, vLLM — and set the
# models to one you have pulled.
OPENAI_API_KEY=
OPENAI_BASE_URL=
RERANK_MODEL=gpt-4o-mini
RERANK_TOP=30
ASK_MODEL=gpt-4o-mini
ASK_CHAR_BUDGET=90000
ASK_RECENT_DAYS=5

# ─── SYNC SCRIPTS (client-side .env) ─────────────────────────────────────────
# These are NOT read by the server. They're documented here so you can copy
# them into scripts/sync/.env on each client machine that pushes chats.
#
# COCKPIT_HOST=192.168.1.10          # IP or hostname of the cockpit server
# COCKPIT_USER=cockpit               # SSH user on the cockpit server
# COCKPIT_DATA_ROOT=/srv/cockpit/data
# CLIENT_NAME=laptop                 # arbitrary tag — becomes folder name
